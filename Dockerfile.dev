# Development image — full deps, hot reload. Source is bind-mounted by docker-compose.yml.
FROM node:22-bookworm-slim

# Prisma needs OpenSSL (both for engine codegen and at runtime).
RUN apt-get update -y \
    && apt-get install -y --no-install-recommends openssl ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Pin pnpm via corepack to match the lockfile toolchain.
RUN corepack enable && corepack prepare pnpm@11.3.0 --activate

WORKDIR /app

# Install deps first for better layer caching.
# prisma/ is copied because the `postinstall` hook runs `prisma generate`.
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY prisma ./prisma
RUN pnpm install --frozen-lockfile

# Fallback copy for runs without a bind mount (compose mounts the source over this).
COPY . .

EXPOSE 3000
# The real start command (migrate + seed + dev) is supplied by docker-compose.yml.
CMD ["pnpm", "dev"]
